{
    "name": "mud-qadm/policy-discovery",
    "description": "Laravel package for recursive policy auto discovery supporting modular architecture",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "MudQadm\\PolicyDiscovery\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MudQadm\\PolicyDiscovery\\PolicyDiscoveryServiceProvider"
            ]
